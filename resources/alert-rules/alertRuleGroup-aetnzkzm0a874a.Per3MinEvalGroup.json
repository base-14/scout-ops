              "range": true,
              "rawQuery": "/* grafana dashboard=$__dashboard, user='6' */\nSELECT (intDiv(toFloat64(TimeUnix) * 1000, (5 * 1000)) * (5 * 1000)) as t, count(Value), Attributes['OutboundAPI'] as endpoint, Attributes['StatusCode'] as status_code\nFROM dpd0.otel_metrics_gauge \nWHERE TimeUnix \u003e= toDateTime64(1758092219,3) AND TimeUnix \u003c= toDateTime64(1758103019,3) \nAND ServiceName = 'finmo'\nAND MetricName = 'outbound_request_time'\nAND Attributes['Method'] = 'POST'\nAND Attributes['StatusCode'] not like '2%'\nAND ResourceAttributes['environment'] = 'production'\nAND endpoint like 'intalk_%'\nGROUP BY t, endpoint, status_code\nORDER BY t",
